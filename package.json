{
  "name": "@elio1995/strata",
  "version": "0.1.0",
  "description": "Typed TypeScript SDK wrapping the Open-Meteo weather API: retries with exponential backoff, request deduplication, timeouts, discriminated-union error types, ESM + CJS + UMD builds.",
  "keywords": [
    "weather",
    "open-meteo",
    "sdk",
    "typescript",
    "forecast",
    "geocoding",
    "air-quality",
    "esm",
    "cjs",
    "umd"
  ],
  "license": "MIT",
  "author": {
    "name": "Elio Mehmeti",
    "email": "mehmetielio95@gmail.com"
  },
  "homepage": "https://github.com/elio1995/strata#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elio1995/strata.git"
  },
  "bugs": {
    "url": "https://github.com/elio1995/strata/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./umd/strata.js",
  "jsdelivr": "./umd/strata.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": ["dist", "umd", "README.md", "ARCHITECTURE.md", "LICENSE"],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist umd coverage .tsbuildinfo",
    "dev": "rollup -c rollup.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepublishOnly": "pnpm run clean && pnpm run typecheck && pnpm run test && pnpm run build",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run --no-ci",
    "demo": "cd demo && pnpm run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^20.17.10",
    "@vitest/coverage-v8": "^2.1.8",
    "rollup": "^4.28.1",
    "rollup-plugin-dts": "^6.1.1",
    "semantic-release": "^24.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
